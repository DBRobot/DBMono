{
  "version": 4,
  "configurations": [
    {
      "name": "STM32G474",
      "compilerPath": "${env:HOME}/snap/code/current/.local/share/stm32cube/bundles/gnu-tools-for-stm32/14.3.1+st.2/bin/arm-none-eabi-gcc",
      "compilerArgs": [
        "-mcpu=cortex-m4",
        "-mfpu=fpv4-sp-d16",
        "-mfloat-abi=hard",
        "-mthumb"
      ],
      "includePath": [
        "${workspaceFolder}/Protocols/drivers/includes",
        "${workspaceFolder}/Protocols/libs/cmsis_core/CMSIS/Core/Include",
        "${workspaceFolder}/Protocols/libs/cmsis_device_g4/Include"
      ],
      "defines": [
        "STM32G474xx"
      ],
      "cStandard": "c11",
      "intelliSenseMode": "linux-gcc-arm"
    }
  ]
}
